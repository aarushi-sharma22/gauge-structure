        "\n",
        "def load_model(name):\n",
        "    tok = AutoTokenizer.from_pretrained(name)\n",
        "    tok.pad_token = tok.pad_token or tok.eos_token\n",
        "    m = AutoModelForCausalLM.from_pretrained(name, torch_dtype=torch.bfloat16,\n",
        "                                             device_map=\"auto\")\n",
        "    m.eval()\n",
        "    if getattr(m.config, \"tie_word_embeddings\", False):\n",
        "        head = m.get_output_embeddings()\n",
        "        nh = torch.nn.Linear(head.in_features, head.out_features, bias=False)\n",
        "        nh.weight = torch.nn.Parameter(head.weight.detach().clone())\n",
        "        m.set_output_embeddings(nh.to(head.weight.device, head.weight.dtype))\n",
        "        m.config.tie_word_embeddings = False\n",
        "        print(\"  [untied embeddings]\")\n",
        "    return tok, m\n",
        "\n",
        "def resolve_single_tokens(tok, words):\n",
        "    for p in (\" \", \"\"):\n",
        "        ids = [tok.encode(p+w, add_special_tokens=False) for w in words]\n",
        "        if all(len(t) == 1 for t in ids):\n",
        "            return p, [t[0] for t in ids]\n",
        "    return None, None\n",
        "\n",
        "@contextmanager\n",
        "def swapped(model, ids, new_in, new_out=None):\n",
        "    \"\"\"Swap input-embedding rows; optionally ALSO the unembedding rows (arm B2).\"\"\"\n",
        "    emb = model.get_input_embeddings().weight\n",
        "    idx = torch.tensor(ids, device=emb.device)\n",
        "    b_in = emb.data[idx].clone()\n",
        "    head = model.get_output_embeddings().weight\n",
        "    b_out = head.data[idx].clone() if new_out is not None else None\n",
        "    try:\n",
        "        emb.data[idx] = torch.tensor(new_in, dtype=emb.dtype, device=emb.device)\n",
        "        if new_out is not None:\n",
        "            head.data[idx] = torch.tensor(new_out, dtype=head.dtype, device=head.device)\n",
        "        yield\n",
        "    finally:\n",
        "        emb.data[idx] = b_in\n",
        "        if b_out is not None:\n",
        "            head.data[idx] = b_out\n",
        "\n",
        "@torch.no_grad()\n",
        "def score(model, tok, prompts, cand_ids, batch=16):\n",
        "    \"\"\"Returns (argmax candidate index, logit margin) per prompt.\"\"\"\n",
        "    preds, margins = [], []\n",
        "    for i in range(0, len(prompts), batch):\n",
        "        enc = tok(prompts[i:i+batch], return_tensors=\"pt\", padding=True).to(model.device)\n",
        "        out = model(**enc)\n",
        "        last = enc.attention_mask.sum(1) - 1\n",
        "        lg = out.logits[torch.arange(len(last)), last][:, cand_ids].float()\n",
        "        top = lg.argmax(-1)\n",
        "        preds.extend(top.tolist())\n",
        "        srt = lg.sort(dim=-1, descending=True).values\n",
        "        margins.extend((srt[:, 0] - srt[:, 1]).tolist())\n",
        "    return np.array(preds), np.array(margins)"
