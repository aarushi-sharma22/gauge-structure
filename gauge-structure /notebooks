        "        evaluate(f\"E_matchD_{ri}\", match_magnitude(X, XEfull, TARGET_D))\n",
        "\n",
        "    pd.DataFrame(records).to_csv(\"sym_records.csv\", index=False)\n",
        "    pd.DataFrame(did_rows).to_csv(\"sym_did.csv\", index=False)\n",
