      "source": [
        "\"\"\"Core for Exp 3 (symmetry breaking) and Exp 4 (symmetry perfection) on\n",
        "cyclic token structure in LLM parameter space.\n",
        "\n",
        "THE OBJECT. X in R^{n x d}: rows = embeddings of the n cyclic tokens (months).\n",
        "The Z/n symmetry is EQUIVARIANCE: does an orthogonal R exist with\n",
        "X_{t+1} = R X_t for all t?  Equivalently, per Fourier mode k with content\n",
        "C_k = [a_k; b_k] (2 x d), equivariance requires |a_k| = |b_k| and a_k _|_ b_k,\n",
        "i.e. each mode traces a CIRCLE not an ELLIPSE.\n",
        "\n",
        "KEY POINT (this is what makes the experiment new): deleting Fourier modes does\n",
        "NOT reduce symmetry -- every mode is an irrep of Z/n, so circle-only is just as\n",
        "equivariant as the full structure. The real symmetry defect is the ELLIPTICITY\n",
        "of the modes, which is measurably nonzero in real LLMs (circularity 0.86-0.96).\n",
        "\n",
        "DEFECT (the manipulated quantity):\n",
        "  delta_equi(X) = min_{R in O(d)} sum_t ||X_{t+1} - R X_t||^2 / sum_t ||X_t||^2\n",
        "  Closed form via orthogonal Procrustes on M = sum_t X_{t+1} X_t^T.\n",
        "\n",
        "PERTURBATION FAMILIES (all applied to the n token rows):\n",
        "  A  cyclic_relabel(s)    exact group element (uniform phase 2*pi*k*s/n per mode).\n",
        "                          Preserves EVERYTHING incl. delta_equi. Positive control:\n",
        "                          answers should shift by exactly s.\n",
        "  B  gauge_perturb        independent per-mode phase + scale (the COMMUTANT of the\n",
        "                          Z/n action). Preserves equivariance, mode energies,\n",
        "                          circularity, delta_equi. Changes only convention/positions.\n",
        "  C  break_symmetry(lam)  ellipticity injection at FIXED per-mode energy:\n",
        "                          svals (s1,s2) -> (s1*lam, s2/lam), renormalised.\n",
        "                          Raises delta_equi. Preserves mode energies + token\n",
        "                          distinguishability. <-- THE CORE TEST\n",
        "  D  perfect_symmetry     equalise mode svals -> (sbar, sbar), sbar preserving\n",
        "                          energy. Drives delta_equi toward 0. <-- EXP 3 (\"what if\n",
        "                          we force perfect symmetry?\")\n",
        "  E  matched_random       energy-matched random content. Baseline.\n",
        "\n",
        "Every family asserts its invariants at runtime (see assert_invariants).\n",
        "\"\"\"\n",
        "import numpy as np\n",
        "\n",
        "\n",
        "# --------------------------------------------------------------------------\n",
        "def fourier_modes(n):\n",
        "    j = np.arange(n)\n",
        "    modes = [(0, np.ones((n, 1)) / np.sqrt(n))]\n",
        "    for k in range(1, n // 2 + 1):\n",
        "        c, s = np.cos(2 * np.pi * k * j / n), np.sin(2 * np.pi * k * j / n)\n",
        "        M = np.column_stack([c, s]) if (2 * k != n) else c[:, None]\n",
        "        Q, _ = np.linalg.qr(M)\n",
        "        modes.append((k, Q))\n",
        "    assert sum(B.shape[1] for _, B in modes) == n\n",
        "    return modes\n",
        "\n",
        "\n",
        "def shift_matrix(n):\n",
        "    \"\"\"Token-index cyclic shift S: (S X)_t = X_{t-1}.\"\"\"\n",
        "    S = np.zeros((n, n))\n",
        "    for t in range(n):\n",
        "        S[t, (t - 1) % n] = 1.0\n",
        "    return S\n",
        "\n",
        "\n",
        "def equivariance_defect(X):\n",
        "    \"\"\"delta_equi in [0, ~2]. 0 = exactly equivariant (an orthogonal R implements\n",
        "    the token shift). Uses orthogonal Procrustes; centered rows.\"\"\"\n",
        "    n = X.shape[0]\n",
        "    Xc = X - X.mean(axis=0, keepdims=True)\n",
        "    Xn = shift_matrix(n) @ Xc                      # rows shifted by +1\n",
        "    M = Xn.T @ Xc                                   # d x d\n",
        "    U, s, Vt = np.linalg.svd(M)\n",
        "    R = U @ Vt                                      # argmin_R ||Xn - Xc R^T||\n",
        "    num = np.linalg.norm(Xn - Xc @ R.T) ** 2\n",
        "    den = np.linalg.norm(Xc) ** 2\n",
        "    return float(num / den)\n",
        "\n",
        "\n",
        "def mode_stats(X, modes):\n",
        "    \"\"\"Per mode: energy, singular values, circularity s2/s1.\"\"\"\n",
        "    Xc = X - X.mean(axis=0, keepdims=True)\n",
        "    out = {}\n",
        "    for k, B in modes:\n",
        "        if k == 0:\n",
        "            continue\n",
        "        C = B.T @ Xc\n",
        "        s = np.linalg.svd(C, compute_uv=False)\n",
        "        s = np.pad(s, (0, max(0, 2 - len(s))))\n",
        "        out[k] = dict(energy=float(np.sum(C ** 2)),\n",
        "                      s1=float(s[0]), s2=float(s[1]),\n",
        "                      circularity=float(s[1] / s[0]) if s[0] > 1e-12 else 0.0)\n",
        "    return out\n",
        "\n",
        "\n",
        "# --------------------------------------------------------------------------\n",
        "# perturbation families\n",
        "# --------------------------------------------------------------------------\n",
        "def _rebuild(X, modes, transform):\n",
        "    \"\"\"Rebuild X from per-mode contents, applying transform(k, C_k) to each\n",
        "    2-row mode. Mode 0 (mean) and any 1-d Nyquist mode pass through.\"\"\"\n",
        "    Xc = X - X.mean(axis=0, keepdims=True)\n",
        "    out = np.zeros_like(Xc)\n",
        "    for k, B in modes:\n",
        "        C = B.T @ Xc\n",
        "        if k == 0 or C.shape[0] != 2:\n",
        "            out += B @ C\n",
        "        else:\n",
        "            out += B @ transform(k, C)\n",
        "    return out + X.mean(axis=0, keepdims=True)\n",
        "\n",
        "\n",
        "def cyclic_relabel(X, modes, s):\n",
        "    \"\"\"FAMILY A. Exact group element: rotate mode k by phase 2*pi*k*s/n.\n",
        "    Equivalent to relabelling token t -> t+s. Preserves every invariant.\"\"\"\n",
        "    n = X.shape[0]\n",
        "    def T(k, C):\n",
        "        th = 2 * np.pi * k * s / n\n",
        "        R = np.array([[np.cos(th), np.sin(th)], [-np.sin(th), np.cos(th)]])\n",
        "        return R @ C\n",
        "    return _rebuild(X, modes, T)\n",
        "\n",
        "\n",
        "def gauge_perturb(X, modes, rng, scale_sd=0.0):\n",
        "    \"\"\"FAMILY B. Independent per-mode phase (and optional scale) = the COMMUTANT.\n",
        "    Preserves equivariance, per-mode energy, circularity, delta_equi.\n",
        "    Changes only the absolute positions/convention.\n",
        "    NOTE scale_sd>0 breaks exact energy matching per mode; default 0 keeps it.\"\"\"\n",
        "    def T(k, C):\n",
        "        th = rng.uniform(0, 2 * np.pi)\n",
        "        R = np.array([[np.cos(th), np.sin(th)], [-np.sin(th), np.cos(th)]])\n",
        "        C2 = R @ C\n",
        "        if scale_sd > 0:\n",
        "            C2 = C2 * float(np.exp(rng.normal(0, scale_sd)))\n",
        "        return C2\n",
        "    return _rebuild(X, modes, T)\n",
        "\n",
        "\n",
        "def break_symmetry(X, modes, lam, rng=None, per_mode_random=False):\n",
        "    \"\"\"FAMILY C (core test). Inject ELLIPTICITY at fixed per-mode energy:\n",
        "    C = U diag(s1, s2) V^T  ->  U diag(s1*lam, s2/lam) V^T, renormalised so the\n",
        "    mode's Frobenius energy is unchanged. lam > 1 raises delta_equi.\n",
        "    per_mode_random: randomise which axis is stretched (avoids a coherent global\n",
        "    distortion that a reader could trivially undo).\"\"\"\n",
        "    def T(k, C):\n",
        "        U, s, Vt = np.linalg.svd(C, full_matrices=False)\n",
        "        s = np.pad(s, (0, max(0, 2 - len(s))))\n",
        "        # SVD orders s1 >= s2, so lam>1 always STRETCHES the dominant axis =>\n",
        "        # ellipticity increases monotonically. (An earlier version randomised the\n",
        "        # axis, which could accidentally CIRCULARISE an already-elliptical mode\n",
        "        # and lower the defect -- a bug caught by the invariant assertion.)\n",
        "        l = lam\n",
        "        s_new = np.array([s[0] * l, s[1] / l])\n",
        "        e_old = np.sum(s ** 2)\n",
        "        e_new = np.sum(s_new ** 2)\n",
        "        if e_new > 1e-18:\n",
        "            s_new = s_new * np.sqrt(e_old / e_new)      # exact energy match\n",
        "        return U @ np.diag(s_new) @ Vt\n",
        "    return _rebuild(X, modes, T)\n",
        "\n",
        "\n",
        "def perfect_symmetry(X, modes):\n",
        "    \"\"\"FAMILY D (Exp 3). Force each mode to be a perfect CIRCLE: equalise the two\n",
        "    singular values (sbar preserving the mode's energy). Drives delta_equi -> 0\n",
        "    while preserving per-mode energy exactly.\"\"\"\n",
        "    def T(k, C):\n",
        "        U, s, Vt = np.linalg.svd(C, full_matrices=False)\n",
        "        s = np.pad(s, (0, max(0, 2 - len(s))))\n",
        "        sbar = np.sqrt(np.sum(s ** 2) / 2.0)\n",
        "        return U @ np.diag([sbar, sbar]) @ Vt\n",
        "    return _rebuild(X, modes, T)\n",
        "\n",
        "\n",
        "def matched_random(X, modes, rng):\n",
        "    \"\"\"FAMILY E. Replace each mode's content with random content of the same\n",
        "    Frobenius energy.\"\"\"\n",
        "    def T(k, C):\n",
        "        R = rng.standard_normal(C.shape)\n",
        "        nr = np.linalg.norm(R)\n",
        "        return R * (np.linalg.norm(C) / nr) if nr > 0 else C\n",
        "    return _rebuild(X, modes, T)\n",
        "\n",
        "\n",
        "# --------------------------------------------------------------------------\n",
        "# magnitude matching + invariant assertions\n",
        "# --------------------------------------------------------------------------\n",
        "def perturbation_magnitude(X, Y):\n",
        "    \"\"\"Two reported criteria (a reviewer WILL poke the normalisation):\n",
        "    frob      = ||Y - X||_F / ||X||_F\n",
        "    mean_disp = mean_t ||y_t - x_t|| / mean_t ||x_t||   (per-token displacement)\"\"\"\n",
        "    d = Y - X\n",
        "    return dict(frob=float(np.linalg.norm(d) / np.linalg.norm(X)),\n",
        "                mean_disp=float(np.mean(np.linalg.norm(d, axis=1)) /\n",
        "                                np.mean(np.linalg.norm(X, axis=1))))\n",
        "\n",
        "\n",
        "def match_magnitude(X, Y, target_frob):\n",
        "    \"\"\"Rescale the perturbation Y-X to hit a target relative Frobenius magnitude,\n",
        "    so families can be compared at equal perturbation size.\"\"\"\n",
        "    d = Y - X\n",
        "    cur = np.linalg.norm(d) / np.linalg.norm(X)\n",
        "    if cur < 1e-12:\n",
        "        return Y.copy()\n",
        "    return X + d * (target_frob / cur)\n",
        "\n",
        "\n",
        "def assert_invariants(X, Y, modes, family, tol=1e-6):\n",
        "    \"\"\"Runtime check that each family preserves what it claims to preserve.\"\"\"\n",
        "    sx, sy = mode_stats(X, modes), mode_stats(Y, modes)\n",
        "    def energies_match():\n",
        "        return all(abs(sx[k]['energy'] - sy[k]['energy'])\n",
        "                   <= tol * max(1.0, sx[k]['energy']) for k in sx)\n",
        "    def circ_match():\n",
        "        return all(abs(sx[k]['circularity'] - sy[k]['circularity']) <= 1e-4\n",
        "                   for k in sx)\n",
        "    dx, dy = equivariance_defect(X), equivariance_defect(Y)\n",
        "    if family in (\"A\", \"B\"):\n",
        "        assert energies_match(), f\"{family}: per-mode energy not preserved\"\n",
        "        assert circ_match(), f\"{family}: circularity not preserved\"\n",
        "        assert abs(dx - dy) < 1e-4, f\"{family}: delta_equi changed ({dx:.5f}->{dy:.5f})\"\n",
        "    elif family == \"C\":\n",
        "        assert energies_match(), \"C: per-mode energy not preserved\"\n",
        "        assert dy > dx + 1e-4, f\"C: delta_equi did not increase ({dx:.5f}->{dy:.5f})\"\n",
        "    elif family == \"D\":\n",
        "        assert energies_match(), \"D: per-mode energy not preserved\"\n",
        "        assert dy < dx - 1e-6 or dy < 1e-6, f\"D: delta_equi did not fall ({dx:.5f}->{dy:.5f})\"\n",
        "        # only modes that carry energy have a meaningful circularity\n",
        "        live = [k for k in sy if sy[k]['energy'] > 1e-9 * max(v['energy'] for v in sy.values())]\n",
        "        assert all(abs(sy[k]['circularity'] - 1.0) < 1e-6 for k in live), \\\n",
        "            \"D: energy-carrying modes not perfectly circular\"\n",
        "    return dict(delta_before=dx, delta_after=dy)\n",
        "\n",
        "\n",
        "# ============================================================================\n",
        "# calibration + statistics for the symmetry experiment\n",
        "# ============================================================================\n",
        "def circularity_weighted(X, modes, min_energy_frac=1e-3):\n",
        "    \"\"\"Energy-weighted mean circularity over modes that actually carry energy.\n",
        "    DIMENSION-INDEPENDENT primary symmetry measure (unlike delta_equi, which\n",
        "    vanishes for random rows as d grows -- see delta_equi_null).\"\"\"\n",
        "    st = mode_stats(X, modes)\n",
        "    tot = sum(v['energy'] for v in st.values())\n",
        "    live = {k: v for k, v in st.items() if v['energy'] > min_energy_frac * tot}\n",
        "    w = sum(v['energy'] for v in live.values())\n",
        "    return float(sum(v['circularity'] * v['energy'] for v in live.values()) / w)\n",
        "\n",
        "\n",
        "def delta_equi_null(n, d, n_draws, rng):\n",
        "    \"\"\"CRITICAL CALIBRATION. Random rows in high d are near-orthonormal, so their\n",
        "    row-Gram ~ I, which IS circulant => they are TRIVIALLY near-equivariant and\n",
        "    delta_equi -> 0 as d grows. A low raw defect therefore means nothing on its\n",
        "    own. Always report delta_equi against this null.\"\"\"\n",
        "    return np.array([equivariance_defect(rng.standard_normal((n, d)))\n",
        "                     for _ in range(n_draws)])\n",
        "\n",
        "\n",
        "def bootstrap_ci_acc(correct, items, n_boot=2000, seed=0, alpha=0.05):\n",
        "    rng = np.random.default_rng(seed)\n",
        "    correct = np.asarray(correct, float); items = np.asarray(items)\n",
        "    uniq = np.unique(items)\n",
        "    members = {c: np.where(items == c)[0] for c in uniq}\n",
        "    st = np.empty(n_boot)\n",
