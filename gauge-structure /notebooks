        "        evaluate(f\"C_break_{lam}\", XC, extra=dict(lam=lam))\n",
        "    # C at the main lambda IS the TARGET_C-magnitude arm (head-to-head vs B1_matchC)\n",
        "    # and a C rescaled to |D| for the D comparison\n",
        "    XCd = match_magnitude(X, break_symmetry(X, modes, LAM_MAIN, rng), TARGET_D)\n",
        "    evaluate(\"C_matchD\", XCd)\n",
        "\n",
        "    # ---------------- ARM D: symmetry perfection --------------------------------\n",
