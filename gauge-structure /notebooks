        "                  + np.sin(2*np.pi*k*j/n)[:, None]*U[:, 2*i+1][None, :])\n",
        "    X += 0.25*(np.cos(2*np.pi*j/n)[:, None]*U[:, 0][None, :])   # LLM-like ellipticity\n",
        "    Xc = X - X.mean(0, keepdims=True)\n",
