        "    if ids is None:\n",
        "        print(\"  months not single-token — EXCLUDED\"); continue\n",
        "    emb = model.get_input_embeddings().weight\n",
        "    head = model.get_output_embeddings().weight\n",
        "    X  = emb.data[torch.tensor(ids, device=emb.device)].float().cpu().numpy()\n",
        "    Wo = head.data[torch.tensor(ids, device=head.device)].float().cpu().numpy()\n",
        "    modes = fourier_modes(12)\n",
        "    d = X.shape[1]\n",
        "\n",
        "    # ---- structure report + the delta_equi null (a LOW raw defect means nothing) ----\n",
        "    null = delta_equi_null(12, d, 40, rng)\n",
        "    circ0, de0 = circularity_weighted(X, modes), equivariance_defect(X)\n",
        "    print(f\"  circularity={circ0:.3f}  delta_equi={de0:.4f}  \"\n",
        "          f\"(random null at d={d}: {null.mean():.4f} +- {null.std():.4f})\")\n",
        "\n",
        "    mgrid = modular_grid()\n",
        "    mprompts = [r[\"prompt\"] for r in mgrid]\n",
        "    mitems = np.array([r[\"item\"] for r in mgrid])\n",
        "    manswers = np.array([r[\"answer\"] for r in mgrid])\n",
        "\n",
        "    def run_mod(Xp, Wp=None):\n",
        "        with swapped(model, ids, Xp, Wp):\n",
        "            p, mg = score(model, tok, mprompts, ids, BATCH)\n",
        "        return (p == manswers).astype(int), mg, p\n",
        "\n",
        "    def run_ctrl(name, Xp, Wp=None):\n",
        "        g, cid = ctrl_grid(name, tok)\n",
        "        if g is None: return None\n",
        "        with swapped(model, ids, Xp, Wp):\n",
        "            p, mg = score(model, tok, [r[\"prompt\"] for r in g], cid, BATCH)\n",
        "        return ((p == np.array([r[\"answer\"] for r in g])).astype(int),\n",
        "                np.array([r[\"item\"] for r in g]), mg)\n",
        "\n",
        "    # ---------------- intact ----------------\n",
        "    c_int, mg_int, _ = run_mod(X)\n",
        "    acc_int, ci_int = bootstrap_ci_acc(c_int, mitems, N_BOOT, SEED)\n",
        "    print(f\"  intact modular acc = {acc_int:.3f} {tuple(round(x,3) for x in ci_int)}\")\n",
        "    if acc_int < 3/12:\n",
        "        print(\"  CAPABILITY GATE FAILED (<3x chance) — arms uninterpretable; EXCLUDED\")\n",
        "        del model; torch.cuda.empty_cache(); continue\n",
        "    ctrl_int = {c: run_ctrl(c, X) for c in CTRL}\n",
        "\n",
        "    # ---------------- ARM A: exact group element (positive control) -------------\n",
        "    XA = cyclic_relabel(X, modes, RELABEL_S)\n",
        "    assert_invariants(X, XA, modes, \"A\")\n",
        "    _, _, pA = run_mod(XA)\n",
        "    shift_rate = float(np.mean(pA == (manswers + RELABEL_S) % 12))\n",
        "    print(f\"  [A] relabel s={RELABEL_S}: targeted-shift rate = {shift_rate:.3f} \"\n",
        "          f\"(chance {1/12:.3f}) {'PASS' if shift_rate >= 3/12 else '** FAIL — experiment VOID **'}\")\n",
        "    records.append(dict(model=mname, arm=\"A\", metric=\"shift_rate\", value=shift_rate))\n",
        "\n",
        "    # TWO magnitude scales (a single one is a trap):\n",
        "    #  - TARGET_C: set by the symmetry-breaking arm at a mid lambda. B1/E are matched\n",
        "    #    to THIS for the head-to-head, else C is too weak to break anything.\n",
        "    #  - TARGET_D: arm D's natural (small) size -- D cannot be rescaled up without\n",
        "    #    overshooting past perfect circularity into the OPPOSITE ellipticity. B1/E are\n",
        "    #    separately matched to |D| for the D comparison.\n",
        "    XD = perfect_symmetry(X, modes)\n",
        "    assert_invariants(X, XD, modes, \"D\")\n",
        "    TARGET_D = perturbation_magnitude(X, XD)[\"frob\"]\n",
        "    LAM_MAIN = LAMBDAS[len(LAMBDAS)//2]\n",
        "    TARGET_C = perturbation_magnitude(X, break_symmetry(X, modes, LAM_MAIN, rng))[\"frob\"]\n",
        "    print(f\"  magnitude scales: |C(lam={LAM_MAIN})| = {TARGET_C:.3f}  |D| = {TARGET_D:.3f}\")\n",
        "\n",
        "    def evaluate(tag, Xp, Wp=None, extra=None):\n",
        "        cm, mgm, _ = run_mod(Xp, Wp)\n",
        "        acc, ci = bootstrap_ci_acc(cm, mitems, N_BOOT, SEED)\n",
        "        row = dict(model=mname, arm=tag, acc=acc, ci_lo=ci[0], ci_hi=ci[1],\n",
        "                   margin=float(mgm.mean()),\n",
        "                   circ=circularity_weighted(Xp, modes),\n",
        "                   delta_equi=equivariance_defect(Xp),\n",
        "                   **perturbation_magnitude(X, Xp), **(extra or {}))\n",
        "        for cname, base in ctrl_int.items():\n",
        "            if base is None: continue\n",
        "            got = run_ctrl(cname, Xp, Wp)\n",
        "            dd = did_bootstrap(c_int, mitems, cm, mitems,\n",
        "                               base[0], base[1], got[0], got[1], 12, N_BOOT, SEED)\n",
        "            row[f\"did_{cname}\"] = dd[\"did\"]\n",
        "            row[f\"did_{cname}_lo\"] = dd[\"ci\"][0]\n",
        "            row[f\"did_{cname}_hi\"] = dd[\"ci\"][1]\n",
        "            did_rows.append(dict(model=mname, arm=tag, control=cname, **dd,\n",
        "                                 mod_drop=float(c_int.mean()-cm.mean()),\n",
        "                                 ctrl_drop=float(base[0].mean()-got[0].mean())))\n",
        "        records.append(row)\n",
        "        did_s = \" \".join(f\"{c}:{row.get(f'did_{c}', float('nan')):+.3f}\" for c in ctrl_int\n",
        "                         if ctrl_int[c] is not None)\n",
        "        print(f\"  [{tag:12s}] acc={acc:.3f} circ={row['circ']:.3f} \"\n",
        "              f\"mag={row['frob']:.3f} DiD {did_s}\")\n",
        "        return row\n",
        "\n",
        "    # ---------------- ARM B1/B2: gauge, input-only vs co-transformed -------------\n",
        "    # B1 is run at BOTH magnitude scales so each head-to-head is matched.\n",
        "    # B2 uses the FULL group element (rescaling it would no longer be a group\n",
        "    # element), so B1_full is also run as its unmatched partner for the recovery test.\n",
        "    for gi in range(N_GAUGE):\n",
        "        g = sample_gauge_element(modes, rng)\n",
        "        XBfull = apply_gauge_element(X, modes, g)\n",
        "        evaluate(f\"B1_matchC_{gi}\", match_magnitude(X, XBfull, TARGET_C))\n",
        "        evaluate(f\"B1_matchD_{gi}\", match_magnitude(X, XBfull, TARGET_D))\n",
        "        evaluate(f\"B1_full_{gi}\", XBfull)                       # B2's matched partner\n",
        "        WB = apply_gauge_element(Wo, modes, g)                  # SAME element\n",
        "        evaluate(f\"B2_cotrans_{gi}\", XBfull, WB)\n",
