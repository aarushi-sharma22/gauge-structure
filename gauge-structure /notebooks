        "def circularity_weighted(X, modes, min_energy_frac=1e-3):\n",
        "    \"\"\"Energy-weighted mean circularity over 2-D modes that carry energy.\n",
        "    ONLY 2-D modes have a meaningful circularity: mode 0 is the mean, and for even n\n",
        "    the Nyquist mode k=n/2 is 1-DIMENSIONAL (a single real direction, no ellipticity).\n",
        "    Including them injects a spurious 0 and depresses the reported value.\"\"\"\n",
        "    st = mode_stats(X, modes)\n",
        "    two_d = {k for k, B in modes if B.shape[1] == 2}\n",
        "    tot = sum(v['energy'] for v in st.values())\n",
        "    live = {k: v for k, v in st.items()\n",
        "            if k in two_d and v['energy'] > min_energy_frac * tot}\n",
        "    w = sum(v['energy'] for v in live.values())\n",
        "    if w <= 0:\n",
        "        return float('nan')\n",
        "    return float(sum(v['circularity'] * v['energy'] for v in live.values()) / w)\n",
        "\n",
        "\n",
        "def assert_invariants(X, Y, modes, family, tol=1e-6):\n",
        "    \"\"\"Runtime check that each family preserves what it claims to preserve.\"\"\"\n",
        "    sx, sy = mode_stats(X, modes), mode_stats(Y, modes)\n",
        "    two_d = {k for k, B in modes if B.shape[1] == 2}\n",
        "\n",
        "    def energies_match():\n",
        "        return all(abs(sx[k]['energy'] - sy[k]['energy'])\n",
        "                   <= tol * max(1.0, sx[k]['energy']) for k in sx)\n",
        "\n",
        "    def circ_match():\n",
        "        return all(abs(sx[k]['circularity'] - sy[k]['circularity']) <= 1e-4\n",
        "                   for k in sx if k in two_d)\n",
        "\n",
        "    dx, dy = equivariance_defect(X), equivariance_defect(Y)\n",
        "\n",
        "    if family in (\"A\", \"B\"):\n",
        "        assert energies_match(), f\"{family}: per-mode energy not preserved\"\n",
        "        assert circ_match(), f\"{family}: circularity not preserved\"\n",
        "        assert abs(dx - dy) < 1e-4, f\"{family}: delta_equi changed ({dx:.5f}->{dy:.5f})\"\n",
        "\n",
        "    elif family == \"C\":\n",
        "        assert energies_match(), \"C: per-mode energy not preserved\"\n",
        "        assert dy > dx + 1e-4, f\"C: delta_equi did not increase ({dx:.5f}->{dy:.5f})\"\n",
        "\n",
        "    elif family == \"D\":\n",
        "        assert energies_match(), \"D: per-mode energy not preserved\"\n",
        "        assert dy < dx - 1e-6 or dy < 1e-6, \\\n",
        "            f\"D: delta_equi did not fall ({dx:.5f}->{dy:.5f})\"\n",
        "        # Only 2-D modes can be circularised. The Nyquist mode (k = n/2) is a single\n",
        "        # real direction with no ellipticity, and mode 0 is the mean -- both are passed\n",
        "        # through unchanged by _rebuild, so neither can (or should) be made circular.\n",
